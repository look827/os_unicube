{
  "entities": {
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback submitted by users about UNICUBE OS.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "vision": {
          "type": "string",
          "description": "The user's vision or feedback for the OS."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the feedback was submitted."
        }
      },
      "required": ["name", "email", "vision", "createdAt"]
    }
  },
  "firestore": {
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedback submissions."
    }
  }
}
